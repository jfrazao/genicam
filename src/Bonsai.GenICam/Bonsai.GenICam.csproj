<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Title>Bonsai - GenICam</Title>
    <Description>Bonsai library for acquiring images and reading/writing features from any GenICam/GenTL-compliant camera without a proprietary SDK.</Description>
    <TargetFramework>net472</TargetFramework>
    <AssemblyName>Bonsai.GenICam</AssemblyName>
    <RootNamespace>Bonsai.GenICam</RootNamespace>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Bonsai.Core" Version="2.9.0" />
    <PackageReference Include="OpenCV.Net" Version="3.4.2" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="System.IO.Compression" />
    <Reference Include="System.IO.Compression.FileSystem" />
    <Reference Include="System.Windows.Forms" />
    <Reference Include="System.Drawing" />
  </ItemGroup>

</Project>
