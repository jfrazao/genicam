<?xml version="1.0" encoding="utf-8"?>
<WorkflowBuilder Version="2.9.0"
                 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                 xmlns:p1="clr-namespace:Bonsai.GenICam;assembly=Bonsai.GenICam"
                 xmlns:rx="clr-namespace:Bonsai.Reactive;assembly=Bonsai.Core"
                 xmlns="https://bonsai-rx.org/2018/workflow">
  <Workflow>
    <Nodes>
      <Expression xsi:type="Combinator">
        <Combinator xsi:type="IntProperty">
          <Value>0</Value>
        </Combinator>
      </Expression>
      <Expression xsi:type="Disable">
        <Builder xsi:type="Combinator">
          <Combinator xsi:type="p1:EnumerateDevices">
            <p1:ProducerPath>C:\Program Files (x86)\Common Files\MVS\Runtime\Win64_x64\MvProducerU3V.cti</p1:ProducerPath>
          </Combinator>
        </Builder>
      </Expression>
      <Expression xsi:type="Disable">
        <Builder xsi:type="Combinator">
          <Combinator xsi:type="rx:Merge" />
        </Builder>
      </Expression>
      <Expression xsi:type="Disable">
        <Builder xsi:type="Combinator">
          <Combinator xsi:type="p1:EnumerateDevices" />
        </Builder>
      </Expression>
      <Expression xsi:type="Disable">
        <Builder xsi:type="Combinator">
          <Combinator xsi:type="rx:Merge" />
        </Builder>
      </Expression>
      <Expression xsi:type="Disable">
        <Builder xsi:type="Combinator">
          <Combinator xsi:type="p1:GetFloatFeature">
            <p1:DeviceIndex>0</p1:DeviceIndex>
            <p1:CameraModel>FLIR Blackfly S BFS-U3-16S2M</p1:CameraModel>
            <p1:FeatureCategory>AcquisitionControl</p1:FeatureCategory>
            <p1:FeatureName>ExposureTime</p1:FeatureName>
            <p1:PeriodMs>1000</p1:PeriodMs>
          </Combinator>
        </Builder>
      </Expression>
      <Expression xsi:type="Disable">
        <Builder xsi:type="Combinator">
          <Combinator xsi:type="p1:GetIntFeature">
            <p1:DeviceIndex>0</p1:DeviceIndex>
            <p1:CameraModel>FLIR Blackfly S BFS-U3-16S2M</p1:CameraModel>
            <p1:FeatureCategory>AcquisitionControl</p1:FeatureCategory>
            <p1:FeatureName>ExposureTime</p1:FeatureName>
            <p1:PeriodMs>1000</p1:PeriodMs>
          </Combinator>
        </Builder>
      </Expression>
      <Expression xsi:type="Disable">
        <Builder xsi:type="Combinator">
          <Combinator xsi:type="p1:GetFeatureNode">
            <p1:DeviceIndex>0</p1:DeviceIndex>
            <p1:FeatureName>AutofeatureAvailableReg</p1:FeatureName>
            <p1:PeriodMs>1000</p1:PeriodMs>
          </Combinator>
        </Builder>
      </Expression>
      <Expression xsi:type="Disable">
        <Builder xsi:type="Combinator">
          <Combinator xsi:type="rx:Timer">
            <rx:DueTime>PT10S</rx:DueTime>
          </Combinator>
        </Builder>
      </Expression>
      <Expression xsi:type="Disable">
        <Builder xsi:type="Combinator">
          <Combinator xsi:type="rx:SubscribeWhen" />
        </Builder>
      </Expression>
      <Expression xsi:type="Combinator">
        <Combinator xsi:type="p1:GenICamCapture">
          <p1:ProducerPath />
          <p1:DeviceIndex>0</p1:DeviceIndex>
          <p1:CameraModel>FLIR Blackfly S BFS-U3-16S2M</p1:CameraModel>
          <p1:Name>flir1</p1:Name>
          <p1:NumBuffers>4</p1:NumBuffers>
          <p1:FrameTimeoutMs>5000</p1:FrameTimeoutMs>
          <p1:Features />
        </Combinator>
      </Expression>
      <Expression xsi:type="MemberSelector">
        <Selector>Image</Selector>
      </Expression>
      <Expression xsi:type="Combinator">
        <Combinator xsi:type="p1:GetFeatureNode">
          <p1:DeviceIndex>0</p1:DeviceIndex>
          <p1:CameraModel>FLIR Blackfly S BFS-U3-16S2M</p1:CameraModel>
          <p1:Connection>flir1</p1:Connection>
          <p1:FeatureCategory>AcquisitionControl</p1:FeatureCategory>
          <p1:FeatureName>ExposureTime</p1:FeatureName>
          <p1:PeriodMs>1000</p1:PeriodMs>
        </Combinator>
      </Expression>
      <Expression xsi:type="Disable">
        <Builder xsi:type="Combinator">
          <Combinator xsi:type="p1:SetFeatureNode">
            <p1:DeviceIndex>0</p1:DeviceIndex>
            <p1:CameraModel>FLIR Blackfly S BFS-U3-16S2M</p1:CameraModel>
            <p1:Connection>flir1</p1:Connection>
            <p1:FeatureCategory>AcquisitionControl</p1:FeatureCategory>
            <p1:FeatureName>ExposureTime</p1:FeatureName>
          </Combinator>
        </Builder>
      </Expression>
    </Nodes>
    <Edges>
      <Edge From="1" To="2" Label="Source1" />
      <Edge From="3" To="4" Label="Source1" />
      <Edge From="7" To="9" Label="Source1" />
      <Edge From="8" To="9" Label="Source2" />
      <Edge From="10" To="11" Label="Source1" />
      <Edge From="12" To="13" Label="Source1" />
    </Edges>
  </Workflow>
</WorkflowBuilder>